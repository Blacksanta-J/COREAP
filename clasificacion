<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clasificación Docente - Criterios 2025</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;600&display=swap');

*{box-sizing:border-box;margin:0;padding:0}
:root{
  --az:#153244;
  --az-hover:#1a3d54;
  --am:#FFCC00;
  --am-light:#fff8cc;
  --cy:#8DE2D6;
  --cy-light:#e8f9f7;
  --cy-mid:#c5f0eb;
  --gr:#3C3C3B;
  --gr-light:#6b6b6a;
  --wh:#FCFCFC;
  --bg:#f0f2f4;
  --surface:#ffffff;
  --border:#e2e6ea;
  --border-strong:#c8cdd3;
  --shadow:0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.05);
  --shadow-md:0 4px 12px rgba(0,0,0,.08),0 2px 4px rgba(0,0,0,.05);
  font-family:'Source Sans 3','Helvetica Neue',Arial,sans-serif;
}

body{background:var(--bg);color:var(--gr);padding:40px}

.wrap{max-width:1280px;margin:0 auto;background:var(--surface);padding:40px;border-radius:12px;box-shadow:var(--shadow-md)}

/* ── Header ─────────────────────────────────── */
.page-header{
  text-align:center;
  padding-bottom:32px;
  border-bottom:3px solid var(--am);
  margin-bottom:40px;
}

.page-header h1{
  font-size:32px;
  font-weight:700;
  color:var(--az);
  margin-bottom:8px;
  letter-spacing:-.5px;
}

.page-header .subtitle{
  font-size:14px;
  color:var(--gr-light);
  font-weight:500;
}

/* ── Info Cards ─────────────────────────────────── */
.info-cards{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:20px;
  margin-bottom:40px;
}

.info-card{
  background:linear-gradient(135deg, var(--az) 0%, var(--az-hover) 100%);
  color:var(--wh);
  padding:20px;
  border-radius:10px;
  box-shadow:var(--shadow);
}

.info-card-label{
  font-size:11px;
  font-weight:700;
  letter-spacing:1.2px;
  text-transform:uppercase;
  color:var(--cy);
  margin-bottom:8px;
}

.info-card-value{
  font-size:16px;
  font-weight:600;
  color:var(--wh);
}

/* ── Section heads ───────────────────────────── */
.sec-head{
  background:var(--az);
  color:var(--wh);
  padding:11px 18px;
  font-size:12px;
  font-weight:700;
  letter-spacing:1.4px;
  text-transform:uppercase;
  margin-bottom:22px;
  margin-top:36px;
  border-radius:6px;
  border-left:4px solid var(--am);
  font-family:'Source Sans 3',sans-serif;
}

.sec-head:first-child{margin-top:0}

.sub-head{
  background:var(--cy-mid);
  color:var(--az);
  padding:9px 18px;
  font-size:11px;
  font-weight:700;
  letter-spacing:.6px;
  margin-bottom:14px;
  margin-top:28px;
  border-radius:4px;
  border-left:3px solid var(--cy);
  font-family:'Source Sans 3',sans-serif;
}

/* ── Alert ───────────────────────────────────── */
.alert{
  background:var(--am-light);
  border-left:4px solid var(--am);
  padding:13px 18px;
  margin:18px 0;
  font-size:13px;
  color:#5a4800;
  display:flex;
  gap:12px;
  align-items:flex-start;
  border-radius:0 6px 6px 0;
}

.alert strong{
  flex-shrink:0;
  font-size:11px;
  font-weight:700;
  letter-spacing:.4px;
  background:var(--am);
  color:var(--az);
  padding:2px 10px;
  border-radius:3px;
  margin-top:2px;
}

/* ── Tables ──────────────────────────────────── */
table{
  width:100%;
  border-collapse:separate;
  border-spacing:0;
  font-size:13px;
  margin-bottom:16px;
  border-radius:8px;
  overflow:hidden;
  box-shadow:var(--shadow);
  background:var(--surface);
}

th{
  background:var(--az);
  color:var(--wh);
  padding:11px 14px;
  text-align:left;
  font-size:11px;
  font-weight:600;
  letter-spacing:.4px;
  text-transform:uppercase;
  font-family:'Source Sans 3',sans-serif;
}

td{
  padding:9px 14px;
  border-bottom:1px solid var(--border);
  vertical-align:top;
  line-height:1.6;
  color:var(--gr);
  font-size:13px;
}

tr:last-child td{border-bottom:none}
tr:nth-child(even) td{background:#f7f9fb}
tr:hover td{background:#f0f4f8;transition:background .1s}

/* ── Badges ──────────────────────────────────── */
.badge{
  display:inline-block;
  padding:2px 8px;
  border-radius:4px;
  font-size:11px;
  font-weight:600;
  letter-spacing:.3px;
}

.badge-tope{background:var(--am-light);color:#5a4800;border:1px solid var(--am)}
.badge-ref{background:var(--cy-light);color:#0a4a42;border:1px solid var(--cy)}

/* ── Def blocks (acordeones) ─────────────────── */
.def-block{
  background:var(--surface);
  border:1px solid var(--border);
  margin-bottom:8px;
  border-radius:8px;
  overflow:hidden;
  box-shadow:var(--shadow);
  transition:box-shadow .2s;
}

.def-block:hover{box-shadow:var(--shadow-md)}

.def-head{
  background:var(--surface);
  color:var(--az);
  padding:14px 18px;
  font-size:14px;
  font-weight:600;
  display:flex;
  justify-content:space-between;
  align-items:center;
  cursor:pointer;
  user-select:none;
  transition:background .15s;
  border-left:4px solid var(--az);
  font-family:'Source Sans 3',sans-serif;
}

.def-head:hover{background:#f4f7fa}

.def-head.open{
  background:#f0f6fa;
  border-left-color:var(--cy);
}

.def-head .arr{
  transition:transform .25s cubic-bezier(.4,0,.2,1);
  font-size:11px;
  color:var(--az);
  opacity:.5;
  width:20px;
  height:20px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:var(--border);
  border-radius:50%;
  flex-shrink:0;
}

.def-head.open .arr{
  transform:rotate(90deg);
  background:var(--cy);
  color:var(--az);
  opacity:1;
}

.def-body{
  background:#f8fbfc;
  padding:18px;
  font-size:13.5px;
  line-height:1.75;
  display:none;
  border-top:1px solid var(--border);
  color:var(--gr);
}

.def-body.open{display:block}

/* ── Highlight box ─────────────────────────────────── */
.highlight-box{
  background:linear-gradient(135deg, var(--cy-light) 0%, var(--cy-mid) 100%);
  border:2px solid var(--cy);
  border-radius:8px;
  padding:16px;
  margin:16px 0;
}

.highlight-box h4{
  color:var(--az);
  font-size:14px;
  font-weight:700;
  margin-bottom:8px;
}

.highlight-box p{
  color:var(--gr);
  font-size:13px;
  line-height:1.6;
}

/* ── List items ─────────────────────────────────── */
ul.criteria-list{
  list-style:none;
  padding:0;
}

ul.criteria-list li{
  padding:10px 0 10px 32px;
  position:relative;
  border-bottom:1px solid var(--border);
  font-size:13px;
  line-height:1.6;
}

ul.criteria-list li:last-child{border-bottom:none}

ul.criteria-list li:before{
  content:'▸';
  position:absolute;
  left:12px;
  color:var(--cy);
  font-weight:700;
}

/* ── Grid layouts ─────────────────────────────────── */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px}

/* ── Reference table ─────────────────────────────────── */
.ref-table{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:8px;
  padding:16px;
  margin-bottom:16px;
}

.ref-table h4{
  color:var(--az);
  font-size:12px;
  font-weight:700;
  letter-spacing:.8px;
  text-transform:uppercase;
  margin-bottom:12px;
  padding-bottom:8px;
  border-bottom:2px solid var(--am);
}

.ref-item{
  padding:6px 0;
  font-size:12px;
  display:flex;
  gap:8px;
}

.ref-item strong{
  color:var(--az);
  min-width:80px;
}

.ref-item span{
  color:var(--gr-light);
}

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 768px) {
  body{padding:20px}
  .wrap{padding:24px}
  .info-cards{grid-template-columns:1fr}
  .grid-2, .grid-3{grid-template-columns:1fr}
}
</style>
</head>
